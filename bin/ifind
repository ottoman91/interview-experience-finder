#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ $# -eq 0 ]]; then
  echo 'usage: ifind "query" | ifind search "query" | ifind reindex | ifind list --limit N' >&2
  exit 1
fi

case "$1" in
  search|reindex|list)
    cd "$REPO_ROOT"
    exec uv run finder "$@"
    ;;
  *)
    cd "$REPO_ROOT"
    exec uv run finder search "$*"
    ;;
esac
